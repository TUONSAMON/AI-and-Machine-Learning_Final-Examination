#--- Question 3: Student Performance Grouping
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.cluster import KMeans

# --- Create DataFrame ---
data = {
    'Study Hours': [1, 2, 1.5, 8, 9, 8.5, 4, 5, 4.5, 7],
    'Exam Score': [40, 42, 38, 90, 95, 92, 65, 70, 68, 85]
}

df = pd.DataFrame(data)

# --- K-Means Clustering (K=3) ---
kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)
df['Cluster'] = kmeans.fit_predict(df[['Study Hours', 'Exam Score']])

print("DataFrame with Cluster Labels:\n")
print(df)

# --- Visualization ---
plt.figure(figsize=(8, 6))
plt.scatter(
    df['Study Hours'],
    df['Exam Score'],
    c=df['Cluster'],
    cmap='viridis',
    s=100
)

plt.title('Student Performance Grouping (K-Means)')
plt.xlabel('Study Hours')
plt.ylabel('Exam Score')
plt.grid(True)
plt.show()
#---(e): Cluster Interpretation--
#Based on the data groupings, the three clusters likely represent:
#Cluster 1 (Low Study/Low Score): "Weak" or "At-risk" students who study very little and have low scores.
#Cluster 2 (Medium Study/Medium Score): "Average" students who put in moderate effort and achieve mid-range scores.
#Cluster 3 (High Study/High Score): "Strong" or "High-achieving" students who study significantly and score high.

#--- (f): Two challenges of K-Means ClusteringChoosing K: The user must manually specify the number of clusters ($K$) beforehand, which isn't always obvious without methods like the "Elbow Curve."Sensitivity to Outliers: Since K-Means uses the mean to calculate centroids, extreme data points (outliers) can significantly pull the centroids away from the actual dense centers of the data.
# (a) Create a DataFrame
import pandas as pd

data = {
    'Hours_Studied': [1, 2, 3, 4, 5, 6, 7, 8],
    'Passed': [0, 0, 0, 1, 1, 1, 1, 1]
}

df = pd.DataFrame(data)
print(df)


# (b) Neural Network Structure (THEORY ONLY)
# A basic neural network consists of three layers:
#
# 1. Input Layer:
#    - Receives input data (e.g., Hours Studied)
#    - Passes data to next layer
#
# 2. Hidden Layer:
#    - Performs computations using weights
#    - Learns patterns in data
#
# 3. Output Layer:
#    - Produces final result (0 or 1)
#    - Uses sigmoid activation for probability


# (c) Build Neural Network using Keras/TensorFlow
import tensorflow as tf
from tensorflow.keras.models import Sequential # type: ignore
from tensorflow.keras.layers import Dense # type: ignore

model = Sequential([
    Dense(4, activation='relu', input_shape=(1,)),  # Hidden layer
    Dense(1, activation='sigmoid')                  # Output layer
])

model.compile(
    optimizer='adam',
    loss='binary_crossentropy',
    metrics=['accuracy']
)

# (D)Train model (VERY IMPORTANT)
model.fit(
    df[['Hours_Studied']],
    df['Passed'],
    epochs=200,
    verbose=0
)


# (e) Prediction
import numpy as np

prediction = model.predict(np.array([[3.5]]))

result = "Pass" if prediction[0][0] > 0.5 else "Fail"
print("Prediction:", result)


# (f) Advantages of Neural Networks
# 1. Can learn complex patterns in data
# 2. High accuracy when trained with enough data
# 3. Automatic feature extraction (no manual feature engineering needed)
